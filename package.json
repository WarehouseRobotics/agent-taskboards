{
  "name": "agent-taskboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Single-user scoped Kanban boards with API for AI Agents",
  "engines": {
    "node": ">=22.14.0"
  },
  "scripts": {
    "dev": "concurrently -n api,ui -c blue,magenta \"npm:dev:api\" \"npm:dev:ui\"",
    "dev:api": "tsx watch api/index.ts",
    "dev:ui": "vite",
    "build": "npm run build:api && npm run build:ui",
    "build:api": "tsc -p tsconfig.api.json",
    "build:ui": "vite build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx api/db/migrate.ts",
    "start": "node dist/api/index.js",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run --config vitest.config.ts",
    "test:embeddings": "vitest run --config vitest.config.ts api/embeddings/local.test.ts"
  },
  "dependencies": {
    "@toon-format/toon": "^2.1.0",
    "ajv": "^8.17.1",
    "better-sqlite3": "^11.8.1",
    "bullmq": "^5.73.0",
    "decimal.js": "^10.6.0",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.44.2",
    "express": "^4.21.2",
    "file-type": "^22.0.0",
    "jose": "^6.2.2",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.1.5",
    "node-llama-cpp": "^3.17.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sqlite-vec": "^0.1.9",
    "winston": "^3.19.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.14",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "@vitejs/plugin-react": "^5.1.2",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.1",
    "eslint": "^9.23.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^7.3.0",
    "vitest": "^3.1.1"
  }
}
